{
  "project": {
    "name": "my-project",
    "description": "Project description"
  },
  "metrics": {
    "backend": "jsonl",
    "file": ".claude/metrics/events.jsonl",
    "webhook": null,
    "statsd": null,
    "opentelemetry": null
  },
  "deploy": {
    "command": "ops/deploy.sh",
    "environments": ["dev", "test", "prod"],
    "promotion_order": ["dev", "test", "prod"]
  },
  "pace": {
    "current": "Crawl",
    "walk_threshold_cfr": 10,
    "run_threshold_cfr": 5,
    "run_threshold_fpy": 80
  },
  "floors": {
    "compliance": {
      "file": "floors/compliance.md",
      "guardian": "cro",
      "compiled_dir": ".claude/floors/compliance/compiled"
    },
    "behavioral": {
      "file": "floors/behavioral.md",
      "guardian": "coo",
      "compiled_dir": ".claude/floors/behavioral/compiled"
    }
  },
  "agents": {
    "governance": ["cro", "ciso", "ceo", "cto", "cfo", "coo", "cko"],
    "core": [
      "product-owner",
      "solution-architect",
      "scrum-master",
      "knowledge-ops",
      "platform-ops",
      "compliance-auditor"
    ],
    "specialists": [],
    "reviewers": [],
    "output": []
  },
  "retro": {
    "cadence": 1,
    "note": "Number of items between retros. 1 = retro after every item."
  },
  "knowledge": {
    "cadence": {
      "crawl": 1,
      "walk": 2,
      "run": 4,
      "fly": 0
    },
    "note": "Items between knowledge distributions per pace. 0 = on-demand/retro only."
  },
  "rewards": {
    "escalation_deadline_days": 7,
    "weighting": {
      "tier_multipliers": {
        "governance": 2.0,
        "operational": 1.0
      },
      "type_multipliers": {
        "kudo": 1.0,
        "reprimand": 1.5
      },
      "domain_multipliers": {
        "collaboration": 1.2,
        "delivery": 1.5,
        "quality": 1.3,
        "governance": 2.0
      },
      "decay": {
        "half_life_days": 30,
        "floor": 0.1
      }
    }
  },
  "rewards_note": "escalation_deadline_days: days before unacted specialist proposals auto-escalate. weighting: multipliers for tier (governance/operational), type (kudo/reprimand), and domain (collaboration/delivery/quality/governance); decay: behavioral scoring decay with 30-day half-life and 0.1 floor.",
  "consultation": {
    "max_rounds": 2,
    "budget_tokens_hint": 50000
  },
  "consultation_note": "CFO-monitored advisory token budgeting system. max_rounds limits consultation iterations per item; budget_tokens_hint is a soft target for token consumption per consultation cycle. Exceeded budgets are logged as signals but do not prevent work continuation.",
  "prioritize_cadence": "per-iteration",
  "prioritize_cadence_note": "When Phase 0 (Prioritize) runs. Options: per-iteration (default), per-session, per-item.",
  "pathways": {
    "declared": {
      "build": [
        "product-owner -> backend-specialist",
        "product-owner -> frontend-specialist",
        "backend-specialist -> security-reviewer",
        "frontend-specialist -> e2e-test-engineer",
        "security-reviewer -> product-owner",
        "e2e-test-engineer -> product-owner"
      ],
      "review": [
        "product-owner -> security-reviewer",
        "product-owner -> e2e-test-engineer"
      ],
      "escalation": [
        "* -> solution-architect",
        "* -> scrum-master",
        "* -> product-owner"
      ],
      "governance": [
        "ciso -> cro",
        "cro -> compliance-auditor",
        "* -> cro",
        "cko -> knowledge-ops",
        "cto -> solution-architect",
        "cfo -> platform-ops",
        "coo -> scrum-master",
        "* -> ceo"
      ],
      "feedback": [
        "backend-specialist -> solution-architect",
        "security-reviewer -> ciso",
        "frontend-specialist -> product-owner",
        "e2e-test-engineer -> product-owner"
      ],
      "feedback_note": "Specialist-to-supervisor mapping for behavioral feedback proposals. Fallback: escalation wildcards."
    },
    "note": "Declared pathways define expected agent-to-agent communication routes. Actual pathways are inferred from handoff events. The delta between declared and actual is the signal: undeclared paths may indicate innovation or governance bypass."
  }
}
