{
  "project": {
    "name": "ecommerce-platform",
    "description": "E-commerce platform with React frontend and Node.js backend"
  },
  "metrics": {
    "backend": "jsonl",
    "file": ".claude/metrics/events.jsonl",
    "webhook": null,
    "statsd": null,
    "opentelemetry": null
  },
  "deploy": {
    "command": "ops/deploy.sh",
    "environments": ["dev", "staging", "prod"]
  },
  "pace": {
    "current": "Crawl",
    "walk_threshold_cfr": 10,
    "run_threshold_cfr": 5,
    "run_threshold_fpy": 80
  },
  "agents": {
    "core": ["product-owner", "solution-architect", "scrum-master", "memory-manager", "platform-ops"],
    "specialists": ["frontend-specialist", "backend-specialist"],
    "reviewers": [],
    "output": []
  },
  "retro": {
    "cadence": 2,
    "note": "Every 2 items. Override from default of 1."
  }
}
